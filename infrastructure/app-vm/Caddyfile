# Global options
{
	# Structured JSON access logs picked up by Grafana Alloy
	log {
		output stdout
		format json
		level INFO
	}
}

# ---------------------------------------------------------------------------
# Template: add one block per hosted app.
# Replace <app-name> and <domain> with real values.
# The upstream address must match the service name in docker-compose.yml.
#
# When the app container is down (502) or restarting (503/504),
# serve the static maintenance page instead of a raw error.
# ---------------------------------------------------------------------------

data-collection.piotrmarzec.info {
	log {
		output stdout
		format json
	}

	reverse_proxy dc-app:9666

	handle_errors 502 503 504 {
		root * /srv/maintenance
		rewrite * /index.html
		file_server
	}
}

regie.kapibara.cloud {
	log {
		output stdout
		format json
	}

	reverse_proxy regie:3000

	handle_errors 502 503 504 {
		root * /srv/maintenance
		rewrite * /index.html
		file_server
	}
}

{
  "uid": "container-metrics",
  "title": "Container Metrics",
  "tags": ["containers", "cadvisor"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(container_cpu_usage_seconds_total{name!=\"\"}, host)",
        "label": "Host",
        "multi": true,
        "includeAll": true,
        "current": {}
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(container_cpu_usage_seconds_total{name!=\"\", host=~\"$host\"}, name)",
        "label": "Container",
        "multi": true,
        "includeAll": true,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Container CPU Usage %",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"$container\", host=~\"$host\"}[5m]) * 100",
          "legendFormat": "{{ name }} ({{ host }})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Container Memory Usage (bytes)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"$container\", host=~\"$host\"}",
          "legendFormat": "{{ name }} ({{ host }})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Container Network Rx (bytes/s)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"$container\", host=~\"$host\"}[5m])",
          "legendFormat": "{{ name }} ({{ host }})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Container Network Tx (bytes/s)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"$container\", host=~\"$host\"}[5m])",
          "legendFormat": "{{ name }} ({{ host }})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Container Restarts (last 1h)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(container_start_time_seconds{name=~\"$container\", host=~\"$host\"}[1h])",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    }
  ]
}
